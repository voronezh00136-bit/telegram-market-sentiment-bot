# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://marketbot:marketbot@db/marketbot

# Optional: NewsAPI key for extended headline coverage
NEWS_API_KEY=your_news_api_key_here

# Sentiment backend: "vader" (default, no download needed) or "transformers"
SENTIMENT_MODEL=vader
